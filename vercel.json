{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/rep", "destination": "/rep.html" },
    { "source": "/board", "destination": "/board.html" },
    { "source": "/crm", "destination": "/crm.html" },
    { "source": "/lead", "destination": "/lead.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/notice", "destination": "/notice.html" },
    { "source": "/invoice", "destination": "/invoice.html" }
  ],
  "cleanUrls": true
}
