# Allison Storm Command — environment (names only, NO real values).
# Set these in Vercel project env at deploy time. Local dev/tests run without them.

# Upstash / Vercel KV REST (NOT UPSTASH_*). Unset -> in-memory fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Operator gate for /board, /crm, api/board (local/test default: AllisonStorm-Cmd-2026)
BOARD_PASSWORD=

# Rep credentials map: "name:passcode,name2:passcode2" (never commit real values)
REP_CREDENTIALS=

# DNC scrub provider (fail-safe: unset -> cold leads withheld)
DNC_PROVIDER=
DNC_API_KEY=

# Cron / scheduled import secret (gates api/storm-import)
CRON_SECRET=

# Email notifications (future phase; unused in Core)
RESEND_API_KEY=
NOTIFY_TO=

# HMAC secrets
SESSION_SECRET=
LEDGER_SECRET=

# Commission rate (locked at 20% of profit)
COMMISSION_RATE=0.20
