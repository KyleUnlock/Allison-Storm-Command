# Allison Storm Command — environment (names only, NO real values).
# Set these in Vercel project env at deploy time. Local dev/tests run without them.

# Upstash / Vercel KV REST (NOT UPSTASH_*). Unset -> in-memory fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Operator gate for /board, /crm, api/board (local/test default: AllisonStorm-Cmd-2026)
BOARD_PASSWORD=

# Rep credentials map: "name:passcode,name2:passcode2" (never commit real values)
REP_CREDENTIALS=

# DNC scrub provider (fail-safe: unset -> cold leads withheld)
DNC_PROVIDER=
DNC_API_KEY=

# Cron / scheduled import secret (gates api/storm-import)
CRON_SECRET=

# Live NWS hail feed (Phase E). SHIP DARK: unset/0 -> the sync stub answer is
# used (conservative "no confirmed report"). Set STORM_LIVE=1 ONLY after
# verifying the endpoints below return hail LSRs (see docs/RUNBOOK.md Phase E).
# Sources are free + keyless; every call is fail-safe (a down feed -> not
# reported, never a fabricated hit, never a 500 on the public intake page).
STORM_LIVE=
# IEM Local Storm Reports GeoJSON base + WFO scope. HGX = Houston/Galveston
# (Allison's market). Comma-separate WFOs to widen coverage (e.g. HGX,FWD,EWX).
STORM_LSR_URL=
STORM_LSR_WFO=
# ZIP -> centroid lookup (keyless). Default: api.zippopotam.us/us/
STORM_CENTROID_URL=
# "near" radius in miles (default 25) and lookback window in days (default 365).
STORM_HAIL_RADIUS_MI=
STORM_HAIL_WINDOW_DAYS=
# Per-request fetch timeout ms (default 4000) and hail-result cache TTL ms
# (default 21600000 = 6h). Centroids cache 30d (they do not move).
STORM_FEED_TIMEOUT_MS=
STORM_HAIL_TTL_MS=

# Internal operator notifications (Phase C). FAIL-SAFE: unset -> notify no-ops
# (new-lead + SLA-breach alerts are skipped, never sent to homeowners).
RESEND_API_KEY=
NOTIFY_TO=

# Lead routing + SLA (Phase C).
# Optional territory map "name:zipPrefix,name2:zipPrefix" — matched before the
# round-robin over REP_CREDENTIALS names. Unset -> pure round-robin.
REP_TERRITORIES=
# First-touch SLA threshold in minutes (default 60).
SLA_FIRST_TOUCH_MINUTES=

# Paid-play ad webhooks (Phase D). SHIP DARK: unset -> the webhook fails closed
# (401/403) and creates NO lead. Set these only when the ad accounts are granted.
# Meta Instant Form: app secret signs X-Hub-Signature-256; verify token gates the
# GET subscription handshake.
META_APP_SECRET=
META_VERIFY_TOKEN=
# Google LSA / CallRail: signing key for the HMAC-SHA256 (base64) body signature.
CALLRAIL_SIGNING_KEY=

# HMAC secrets
SESSION_SECRET=
LEDGER_SECRET=

# Commission rate (locked at 20% of profit)
COMMISSION_RATE=0.20
